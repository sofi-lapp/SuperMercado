# Aplicación
spring.application.name=supermercado

# Base de datos MySQL
spring.datasource.url=jdbc:mysql://localhost:3306/emarket_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA — solo valida, Flyway es quien crea
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true
spring.jpa.open-in-view=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# Flyway
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
spring.flyway.baseline-on-migrate=true

# Redis
spring.data.redis.host=localhost
spring.data.redis.port=6379

# JWT
jwt.secret=eMarketSuperSecretKey2026UadeProcesoDesarrolloSoftwareJWT256Bits!!
jwt.expiration=86400000

# Mercado Pago
mercadopago.access.token=

# Cloudinary
cloudinary.cloud.name=
cloudinary.api.key=
cloudinary.api.secret=

# CORS
cors.allowed.origins=http://localhost:5173,http://localhost:3000
